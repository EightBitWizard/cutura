# Public-hoist ESLint and Prettier to the workspace root node_modules. Several
# ESLint plugins are resolved by name from the project root (eslint-config-next
# does this), which pnpm's isolated layout does not expose by default. Without
# this a clean install can leave plugins unresolved and `pnpm lint` fails.
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
